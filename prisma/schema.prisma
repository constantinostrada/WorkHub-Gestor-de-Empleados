// ─────────────────────────────────────────────────────────────────────────────
// Prisma Schema — WorkHub Gestor de Empleados
// ─────────────────────────────────────────────────────────────────────────────
// NOTE: This file lives in infrastructure territory.
//       ORM models NEVER leak into domain or application layers.
//       The PrismaEmployeeRepository maps these models → domain entities.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Area
// ─────────────────────────────────────────────────────────────────────────────
model Area {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  managerId   String?  @map("manager_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt       @map("updated_at")

  manager     Employee?  @relation("AreaManager", fields: [managerId], references: [id])
  employees   Employee[] @relation("AreaEmployees")

  @@index([managerId])
  @@map("areas")
}

// ─────────────────────────────────────────────────────────────────────────────
// Employee
// ─────────────────────────────────────────────────────────────────────────────
model Employee {
  id        String         @id @default(uuid())
  firstName String         @map("first_name")
  lastName  String         @map("last_name")
  email     String         @unique
  phone     String?
  position  String
  salary    Decimal        @db.Decimal(12, 2)
  status    EmployeeStatus @default(ACTIVE)
  hireDate  DateTime       @map("hire_date")
  areaId    String?        @map("area_id")
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt       @map("updated_at")

  area      Area?  @relation("AreaEmployees", fields: [areaId], references: [id])
  managedAreas Area[] @relation("AreaManager")
  timeEntries  TimeEntry[]
  vacations    Vacation[]

  @@index([areaId])
  @@index([status])
  @@map("employees")
}

// ─────────────────────────────────────────────────────────────────────────────
// TimeEntry — daily worked-hours record per employee
// ─────────────────────────────────────────────────────────────────────────────
model TimeEntry {
  id         String   @id @default(uuid())
  employeeId String   @map("employee_id")
  date       DateTime @db.Date
  hours      Decimal  @db.Decimal(4, 2)
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt       @map("updated_at")

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId, date])
  @@map("time_entries")
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE

  @@map("employee_status")
}

// ─────────────────────────────────────────────────────────────────────────────
// Vacation — vacation request with approval workflow
// ─────────────────────────────────────────────────────────────────────────────
model Vacation {
  id         String          @id @default(uuid())
  employeeId String          @map("employee_id")
  startDate  DateTime        @db.Date @map("start_date")
  endDate    DateTime        @db.Date @map("end_date")
  status     VacationStatus  @default(PENDING)
  reason     String?
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt       @map("updated_at")

  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("vacations")
}

enum VacationStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("vacation_status")
}

// ─────────────────────────────────────────────────────────────────────────────
// AuditLog — append-only mutation tracking
// ─────────────────────────────────────────────────────────────────────────────
model AuditLog {
  id           String   @id @default(uuid())
  actorId      String?  @map("actor_id")
  action       String
  resourceType String   @map("resource_type")
  resourceId   String   @map("resource_id")
  detailsJson  Json     @map("details_json")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}
