# ── Database ──────────────────────────────────────────────────────────────────
# Used by Prisma and the application at runtime
DATABASE_URL="postgresql://workhub_user:workhub_pass@localhost:5432/workhub_db?schema=public"

# ── Next.js ───────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="replace-with-a-secure-random-string"
NEXTAUTH_URL="http://localhost:3000"

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV="development"
